# API base URL (no trailing slash). REQUIRED for production (Vercel).
# If unset in production, login/contact/dashboard will fail with "Backend not configured".
# Local dev: leave unset – app uses http://localhost:5000
#   Or set to your Render backend to use it locally: https://rastogicodeworksbackend.onrender.com
# Vercel: Project → Settings → Environment Variables → Add:
#   Name:  VITE_API_URL
#   Value: https://rastogicodeworksbackend.onrender.com
VITE_API_URL=https://rastogicodeworksbackend.onrender.com

# WhatsApp floating button. Number with country code, no + or spaces (e.g. 919876543210).
# If unset, the WhatsApp button is hidden.
# VITE_WHATSAPP_NUMBER=919876543210
# Optional: phone for the floating Call button (tel:). Defaults to VITE_WHATSAPP_NUMBER if unset.
# VITE_PHONE_NUMBER=919876543210
# Optional pre-filled message when user clicks WhatsApp:
# VITE_WHATSAPP_MESSAGE=Hey, I am reaching out from your website. I would like to connect with Rastogi Codeworks. Could we schedule a call?
