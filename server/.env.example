# Server (Render sets PORT automatically; omit for local)
PORT=5000
NODE_ENV=development

# CORS: frontend origin(s). Comma-separated, no trailing slash.
# Production (Render): MUST set to your Vercel URL, e.g. https://rastogicodeworks.vercel.app
# Otherwise login/contact from the live site will be blocked by CORS.
CLIENT_URL=http://localhost:5173

# MongoDB (local or Atlas – see README for setup)
MONGODB_URI=mongodb://localhost:27017/rastogi-coders

# JWT secret (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin user (created on first startup if not exists). Login at /login with this email and password.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Rastogicodes@2026
ADMIN_NAME=Admin

# Email (Resend — https://resend.com). Verify your domain and use a verified From address.
# RESEND_API_KEY=re_xxxx
# MAIL_FROM="Rastogi Codeworks <onboarding@yourdomain.com>"
# Optional override for notification copies (defaults to ADMIN_EMAIL if unset):
# FOUNDER_NOTIFY_EMAIL=founder@yourdomain.com
